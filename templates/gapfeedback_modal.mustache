{{!
    Gap feedback modal template for gapfill question type.

    This template renders the modal content for configuring gap-specific feedback.
    
    @package    qtype_gapfill
    @copyright  2025 Marcus Green
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}

<div class="container-fluid">
    <div class="form-group row mb-3">
        <label for="gapfill-feedback-correct" class="col-md-12 col-form-label font-weight-bold">{{correct}}</label>
        <div class="col-md-12">
            <textarea id="gapfill-feedback-correct" class="form-control" rows="6"></textarea>
        </div>
    </div>
    <div class="form-group row mb-3">
        <label for="gapfill-feedback-incorrect" class="col-md-12 col-form-label font-weight-bold">{{incorrect}}</label>
        <div class="col-md-12">
            <textarea id="gapfill-feedback-incorrect" class="form-control" rows="6"></textarea>
        </div>
    </div>
</div>